<resources>
    <!-- Base theme — Material 3 dynamic color enabled -->
    <style name="Theme.Kavach" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/kavach_primary</item>
        <item name="colorOnPrimary">@color/kavach_on_primary</item>
        <item name="colorPrimaryContainer">@color/kavach_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/kavach_on_primary_container</item>
        <item name="colorSecondary">@color/kavach_secondary</item>
        <item name="colorError">@color/kavach_error</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash screen theme — shows while app loads -->
    <style name="Theme.Kavach.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/kavach_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Kavach</item>
    </style>
</resources>
