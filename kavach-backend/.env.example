ENV=dev
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/kavachAI
REDIS_URL=redis://redis:6379/0
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LLM_FALLBACK_ORDER=groq,anthropic,openai,gemini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

TASK_MODEL_VERDICT=groq/llama-3.3-70b-versatile
TASK_MODEL_REDFLAG_EXPLAIN=anthropic/claude-haiku-4-5-20251001
TASK_MODEL_DEEPCHECK=groq/llama-3.3-70b-versatile
HIGH_CONFIDENCE_THRESHOLD=0.85
LLM_CONFIDENCE_THRESHOLD=0.70

WHATSAPP_PROVIDER=twilio
META_WABA_TOKEN=
META_PHONE_NUMBER_ID=
META_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=kavach
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=kavach-evidence

JWT_SECRET=dev-secret-change-in-prod
JWT_EXPIRY_MINUTES=60
LOG_LEVEL=INFO

# Phase 2
FCM_SERVER_KEY=
ALERT_COOLDOWN_MINUTES=15

# Phase 4 — CORS
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Phase 4 — rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WHATSAPP_RPS=10
RATE_LIMIT_SIGNALS_RPS=5
